<UserControl x:Class="ScreenWatch.App.Views.CategoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ScreenWatch.App.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:EmptyToVisibilityConverter x:Key="EmptyToVis"/>
        <conv:StringToBrushConverter x:Key="StringToBrush"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,12">

            <!-- ===== 分类管理 ===== -->
            <TextBlock Text="分类管理" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>
            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" Padding="16,12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,20">
                <StackPanel>
                    <!-- 添加新分类 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="名称：" VerticalAlignment="Center" FontSize="13"/>
                        <TextBox Width="120" Padding="4,2" VerticalAlignment="Center"
                                 Text="{Binding NewCategoryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="颜色：" VerticalAlignment="Center" FontSize="13" Margin="12,0,0,0"/>
                        <TextBox Width="80" Padding="4,2" VerticalAlignment="Center"
                                 Text="{Binding NewCategoryColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <Rectangle Width="20" Height="20" RadiusX="3" RadiusY="3" Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Fill="{Binding NewCategoryColor, Converter={StaticResource StringToBrush}}"/>
                        <Button Content="添加" Padding="12,4" Margin="12,0,0,0"
                                Command="{Binding AddCategoryCommand}"/>
                    </StackPanel>

                    <!-- 预设颜色 -->
                    <TextBlock Text="预设颜色：" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4,0,4"/>
                    <ItemsControl ItemsSource="{Binding PresetColors}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="24" Height="24" Margin="2" Padding="0"
                                        Click="PresetColor_Click"
                                        Background="{Binding Converter={StaticResource StringToBrush}}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 分类列表 -->
                    <ItemsControl x:Name="CategoryList" ItemsSource="{Binding Categories}" Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="56"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- 分类 Emoji 图标 -->
                                    <TextBlock Grid.Column="0" Text="{Binding IconDisplay}"
                                               FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Padding="4,2" Margin="4,0"
                                             VerticalAlignment="Center"
                                             Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBox Grid.Column="2" Padding="4,2" Margin="4,0"
                                             VerticalAlignment="Center"
                                             Text="{Binding Color, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Grid.Column="3" Content="保存" Padding="8,2" Margin="2,0"
                                            Command="{Binding DataContext.SaveCategoryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Grid.Column="4" Content="删除" Padding="8,2" Margin="2,0"
                                            Command="{Binding DataContext.DeleteCategoryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="暂无分类，请添加" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" Margin="0,8"
                               Visibility="{Binding HasItems, ElementName=CategoryList, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                </StackPanel>
            </Border>

            <!-- ===== 未归类应用 ===== -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="未归类应用" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Margin="12,0,0,0"
                            Visibility="{Binding UnrecognizedCount, Converter={StaticResource EmptyToVis}}">
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource ErrorBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding UnrecognizedCount}" FontSize="12" Foreground="{DynamicResource ErrorBrush}"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                    <TextBlock Text=" 个" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" Padding="16,12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,20">
                <StackPanel>
                    <!-- 批量归类 + 自动分类 + 重置 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="批量归类到：" VerticalAlignment="Center" FontSize="13"/>
                        <ComboBox Width="150" VerticalAlignment="Center" Margin="8,0,0,0"
                                  ItemsSource="{Binding Categories}"
                                  SelectedValue="{Binding BatchCategoryId, Mode=TwoWay}"
                                  SelectedValuePath="CategoryId"
                                  DisplayMemberPath="Name"/>
                        <Button Content="批量归类" Padding="12,4" Margin="8,0,0,0"
                                Command="{Binding BatchAssignCommand}"/>
                        <Button Style="{DynamicResource ModernButton}" Content="🔍 自动分类" Padding="12,4" Margin="16,0,0,0"
                                Click="OnAutoCategorizeClick"/>
                        <Button Style="{DynamicResource ModernButton}" Content="重置全部分类" Padding="12,4" Margin="8,0,0,0"
                                Click="OnResetAllCategoriesClick"/>
                    </StackPanel>

                    <!-- 未归类应用列表 -->
                    <ItemsControl x:Name="UnrecognizedList" ItemsSource="{Binding UnrecognizedApps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                               VerticalAlignment="Center" FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ExeName}"
                                               VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <ComboBox Grid.Column="2" Margin="4,0" VerticalAlignment="Center"
                                              ItemsSource="{Binding DataContext.Categories, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                              SelectedValue="{Binding SelectedCategoryId, Mode=TwoWay}"
                                              SelectedValuePath="CategoryId"
                                              DisplayMemberPath="Name"
                                              SelectionChanged="OnUnrecognizedCategorySelectionChanged"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="所有应用均已归类" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" Margin="0,8"
                               Visibility="{Binding HasItems, ElementName=UnrecognizedList, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
