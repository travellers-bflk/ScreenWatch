<UserControl x:Class="ScreenWatch.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ScreenWatch.App.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,12">

            <!-- ===== 通用设置 ===== -->
            <TextBlock Text="通用设置" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>
            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" Padding="16,12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,20">
                <StackPanel>
                    <!-- 开机自启 -->
                    <CheckBox Content="开机自启动" FontSize="13" Margin="0,4"
                              IsChecked="{Binding IsAutoStartEnabled, Mode=TwoWay}"
                              Command="{Binding ToggleAutoStartCommand}"/>

                    <!-- 闲置阈值 -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBlock Text="闲置阈值：" VerticalAlignment="Center" FontSize="13"/>
                        <TextBox Width="80" Text="{Binding IdleThresholdSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="4,2" VerticalAlignment="Center"/>
                        <TextBlock Text="秒（超过此时间无操作视为闲置）" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- 后台扫描间隔 -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBlock Text="后台扫描间隔：" VerticalAlignment="Center" FontSize="13"/>
                        <TextBox Width="80" Text="{Binding BackgroundScanIntervalSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="4,2" VerticalAlignment="Center"/>
                        <TextBlock Text="秒（每隔此时间扫描后台窗口）" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- 采集窗口标题 -->
                    <CheckBox Content="采集窗口标题" FontSize="13" Margin="0,12,0,0"
                              IsChecked="{Binding CaptureWindowTitle, Mode=TwoWay}"/>
                    <TextBlock Margin="20,4,0,0" FontSize="11" Foreground="{DynamicResource WarningBrush}"
                               Visibility="{Binding ShowPrivacyWarning, Converter={StaticResource BoolToVis}}"
                               Text="⚠ 警告：启用后将记录窗口标题文本，可能包含敏感信息。数据仅存储在本地。"/>

                    <!-- 保存按钮 -->
                    <Button Content="保存设置" Padding="16,4" Margin="0,16,0,0"
                            HorizontalAlignment="Left"
                            Command="{Binding SaveSettingsCommand}"/>
                </StackPanel>
            </Border>

            <!-- ===== 排除白名单 ===== -->
            <TextBlock Text="排除白名单" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>
            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" Padding="16,12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,20">
                <StackPanel>
                    <!-- 添加新规则 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ComboBox Width="100" VerticalAlignment="Center"
                                  SelectedValue="{Binding NewExclusionMatchType, Mode=TwoWay}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="应用名" Tag="exe_name"/>
                            <ComboBoxItem Content="路径" Tag="exe_path"/>
                        </ComboBox>
                        <TextBox Width="200" VerticalAlignment="Center" Margin="8,0,0,0"
                                 Padding="4,2"
                                 Text="{Binding NewExclusionPattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="添加" Padding="12,4" Margin="8,0,0,0"
                                Command="{Binding AddExclusionCommand}"/>
                    </StackPanel>

                    <!-- 规则列表 -->
                    <ItemsControl x:Name="ExclusionList" ItemsSource="{Binding ExclusionRules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding MatchTypeDisplay}"
                                               VerticalAlignment="Center" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Pattern}"
                                               VerticalAlignment="Center" FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                    <CheckBox Grid.Column="2" VerticalAlignment="Center"
                                              IsChecked="{Binding Enabled, Mode=TwoWay}"
                                              Command="{Binding DataContext.ToggleExclusionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                              CommandParameter="{Binding}"/>
                                    <Button Grid.Column="3" Content="删除" Padding="8,2"
                                            Command="{Binding DataContext.RemoveExclusionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="暂无排除规则" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" Margin="0,8"
                               Visibility="{Binding HasItems, ElementName=ExclusionList, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                </StackPanel>
            </Border>

            <!-- ===== 时段配置 ===== -->
            <TextBlock Text="时段配置" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>
            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" Padding="16,12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,20">
                <StackPanel>
                    <!-- 添加新时段 -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Padding="4,2" Margin="0,0,4,0"
                                 Text="{Binding NewPeriodName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Grid.Column="1" Padding="4,2" Margin="0,0,4,0"
                                 Text="{Binding NewPeriodStart, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Grid.Column="2" Padding="4,2" Margin="0,0,4,0"
                                 Text="{Binding NewPeriodEnd, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Grid.Column="3" Padding="4,2" Margin="0,0,4,0"
                                 Text="{Binding NewPeriodWeekdays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="4" Content="添加" Padding="8,2"
                                Command="{Binding AddTimePeriodCommand}"/>
                    </Grid>
                    <TextBlock Text="星期输入：0=日,1=一,2=二,...,6=六，逗号分隔，留空=每天" 
                               FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8"/>

                    <!-- 时段列表 -->
                    <DataGrid ItemsSource="{Binding TimePeriods}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              BorderThickness="1"
                              RowHeight="32"
                              MaxHeight="300">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name, Mode=TwoWay}" Width="120"/>
                            <DataGridTextColumn Header="开始" Binding="{Binding StartTime, Mode=TwoWay}" Width="80"/>
                            <DataGridTextColumn Header="结束" Binding="{Binding EndTime, Mode=TwoWay}" Width="80"/>
                            <DataGridTextColumn Header="星期" Binding="{Binding Weekdays, Mode=TwoWay}" Width="100"/>
                            <DataGridCheckBoxColumn Header="启用" Binding="{Binding Enabled, Mode=TwoWay}" Width="50"/>
                            <DataGridTemplateColumn Header="操作" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="保存" Padding="8,2" Margin="2"
                                                    Command="{Binding DataContext.SaveTimePeriodCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="删除" Padding="8,2" Margin="2"
                                                    Command="{Binding DataContext.DeleteTimePeriodCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
