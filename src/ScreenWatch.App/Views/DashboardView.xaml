<UserControl x:Class="ScreenWatch.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ScreenWatch.App.Converters">
    <UserControl.Resources>
        <conv:DurationConverter x:Key="DurationConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:EmptyToVisibilityConverter x:Key="EmptyToVis"/>
    </UserControl.Resources>

    <Grid>
        <!-- 空数据提示 -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding HasData, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
            <TextBlock Text="暂无使用记录" FontSize="20" Foreground="{DynamicResource SecondaryTextBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="开始使用电脑后，统计数据将在此显示" FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}"
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- 数据内容 -->
        <ScrollViewer Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,12">

                <!-- ===== 汇总卡片 ===== -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 前台时长 -->
                    <Border Grid.Column="0" Background="{DynamicResource CardAccentBlueBrush}" CornerRadius="8" Padding="16,12">
                        <StackPanel>
                            <TextBlock Text="前台时长" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Text="{Binding TotalForegroundDuration}" FontSize="22"
                                       FontWeight="Bold" Foreground="{DynamicResource AccentTextBlueBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 后台时长 -->
                    <Border Grid.Column="2" Background="{DynamicResource CardAccentGrayBrush}" CornerRadius="8" Padding="16,12">
                        <StackPanel>
                            <TextBlock Text="后台时长" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Text="{Binding TotalBackgroundDuration}" FontSize="22"
                                       FontWeight="Bold" Foreground="{DynamicResource AccentTextGrayBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 活跃应用数 -->
                    <Border Grid.Column="4" Background="{DynamicResource CardAccentOrangeBrush}" CornerRadius="8" Padding="16,12">
                        <StackPanel>
                            <TextBlock Text="活跃应用" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="{Binding ActiveAppCount}" FontSize="22"
                                           FontWeight="Bold" Foreground="{DynamicResource AccentTextOrangeBrush}"/>
                                <TextBlock Text=" 个" FontSize="14" Foreground="{DynamicResource AccentTextOrangeBrush}"
                                           VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ===== 按应用排行 ===== -->
                <TextBlock Text="按应用排行" FontSize="15" FontWeight="Bold" Margin="0,8,0,8"/>
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" Padding="12,8"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,16">
                    <StackPanel>
                    <!-- 图例 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Rectangle Fill="{DynamicResource ChartBarBrush}" Width="12" Height="12" VerticalAlignment="Center"/>
                        <TextBlock Text="前台" FontSize="11" VerticalAlignment="Center" Margin="4,0,16,0"/>
                        <Rectangle Fill="{DynamicResource ChartBarBackgroundBrush}" Width="12" Height="12" VerticalAlignment="Center"/>
                        <TextBlock Text="后台" FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding AppBars}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.ToolTip>
                                        <StackPanel>
                                            <TextBlock Text="{Binding ForegroundDuration, StringFormat='前台时间: {0}'}"/>
                                            <TextBlock Text="{Binding BackgroundDuration, StringFormat='后台时间: {0}'}"/>
                                            <TextBlock Text="{Binding TotalDuration, StringFormat='总时长: {0}'}" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid.ToolTip>
                                    <!-- 应用图标 -->
                                    <Image Grid.Column="0" Source="{Binding Icon}"
                                           Width="20" Height="20"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Stretch="Uniform"/>
                                    <!-- 应用名称 -->
                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                               VerticalAlignment="Center" FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                    <!-- 前台/后台条形图 -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                VerticalAlignment="Center" Margin="8,0">
                                        <Rectangle Fill="{DynamicResource ChartBarBrush}" Width="{Binding ForegroundBarWidth}" Height="16"/>
                                        <Rectangle Fill="{DynamicResource ChartBarBackgroundBrush}" Width="{Binding BackgroundBarWidth}" Height="16"/>
                                    </StackPanel>
                                    <!-- 总时长 -->
                                    <TextBlock Grid.Column="3" Text="{Binding TotalDuration}"
                                               VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ===== 按分类汇总 ===== -->
                <TextBlock Text="按分类汇总" FontSize="15" FontWeight="Bold" Margin="0,8,0,8"/>
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" Padding="12,8"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,16">
                    <ItemsControl ItemsSource="{Binding CategoryBars}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding CategoryName}"
                                               VerticalAlignment="Center" FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Rectangle Grid.Column="1" Width="16" Height="16" RadiusX="3" RadiusY="3"
                                               Fill="{Binding ColorBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <Grid Grid.Column="2" Margin="8,0">
                                        <Rectangle Fill="{DynamicResource ChartBarBackgroundBrush}" Height="16" RadiusX="3" RadiusY="3"/>
                                        <Rectangle Fill="{DynamicResource ChartBarBrush}" Width="{Binding BarWidth}" Height="16"
                                                   RadiusX="3" RadiusY="3" HorizontalAlignment="Left"/>
                                    </Grid>
                                    <TextBlock Grid.Column="3" Text="{Binding PercentageText}"
                                               VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Grid.Column="4" Text="{Binding TotalDuration}"
                                               VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- ===== 按天趋势 ===== -->
                <TextBlock Text="按天趋势" FontSize="15" FontWeight="Bold" Margin="0,8,0,8"/>
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" Padding="12,8"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,16">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding DailyBars}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="48" Margin="2,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="160"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="{Binding TotalDuration}"
                                                   HorizontalAlignment="Center" FontSize="9" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <Rectangle Grid.Row="1" Width="28" Height="{Binding BarHeight}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                                   RadiusX="3" RadiusY="3" Fill="{DynamicResource ChartBarBrush}"/>
                                        <StackPanel Grid.Row="2" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding DateLabel}" FontSize="10"
                                                       HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBlock Text="{Binding WeekdayLabel}" FontSize="9"
                                                       HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- ===== 时段分析 ===== -->
                <TextBlock Text="时段分析" FontSize="15" FontWeight="Bold" Margin="0,8,0,8"/>
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" Padding="12,8"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,16">
                    <Grid>
                    <TextBlock Text="暂无时段配置，请在设置页添加时段" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" Margin="0,12"
                               Visibility="{Binding HasPeriodData, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                    <ItemsControl ItemsSource="{Binding PeriodBars}"
                                  Visibility="{Binding HasPeriodData, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding PeriodName}"
                                               VerticalAlignment="Center" FontSize="12"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                VerticalAlignment="Center" Margin="8,0">
                                        <Rectangle Fill="{DynamicResource ChartBarBrush}" Width="{Binding ForegroundBarWidth}" Height="16"/>
                                        <Rectangle Fill="{DynamicResource ChartBarBackgroundBrush}" Width="{Binding BackgroundBarWidth}" Height="16"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding TotalDuration}"
                                               VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
