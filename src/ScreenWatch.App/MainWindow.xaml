<Window x:Class="ScreenWatch.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:ScreenWatch.App.Views"
        mc:Ignorable="d"
        Title="ScreenWatch - 屏幕使用时间统计"
        Height="720" Width="1080"
        MinHeight="560" MinWidth="880"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        StateChanged="OnWindowStateChanged"
        Icon="app.ico">

    <!-- 圆角窗口根容器 + 外阴影 -->
    <Border x:Name="WindowRoot" Background="{DynamicResource BackgroundBrush}" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.22" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== 标题栏：macOS 红绿灯 ===== -->
            <Grid x:Name="TitleBar" Grid.Row="0" Height="40"
                  Background="{DynamicResource CardBackgroundBrush}"
                  MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左上角红绿灯按钮 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                    <Button Style="{DynamicResource ModernTrafficLightClose}" Tag="Close"
                            Width="13" Height="13" Margin="0,0,8,0" Click="OnTrafficLightClick"/>
                    <Button Style="{DynamicResource ModernTrafficLightMinimize}" Tag="Minimize"
                            Width="13" Height="13" Margin="0,0,8,0" Click="OnTrafficLightClick"/>
                    <Button Style="{DynamicResource ModernTrafficLightMaximize}" Tag="Maximize"
                            Width="13" Height="13" Click="OnTrafficLightClick"/>
                </StackPanel>

                <!-- 居中毛玻璃标题 -->
                <TextBlock Grid.Column="1" Text="ScreenWatch — 屏幕使用时间统计"
                           Style="{DynamicResource ModernTitleText}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>


            </Grid>

            <!-- ===== 主体：侧边栏 + 内容区 ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧边栏（半透明卡片式导航） -->
                <Border Grid.Column="0" Style="{DynamicResource ModernSidebar}">
                    <ListBox x:Name="NavigationList" Style="{DynamicResource ModernSidebarList}"
                             SelectionChanged="OnNavigationSelectionChanged">
                        <ListBoxItem Style="{DynamicResource ModernSidebarItem}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="使用汇总" Style="{DynamicResource SidebarItemText}"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Style="{DynamicResource ModernSidebarItem}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="使用详情" Style="{DynamicResource SidebarItemText}"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Style="{DynamicResource ModernSidebarItem}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏷️" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="类别管理" Style="{DynamicResource SidebarItemText}"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Style="{DynamicResource ModernSidebarItem}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙️" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="设置" Style="{DynamicResource SidebarItemText}"/>
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>
                </Border>

                <!-- 内容区（圆角白色卡片布局） -->
                <Grid Grid.Column="1" Margin="20,16,20,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 顶部控制栏卡片 -->
                    <Border Grid.Row="0" Style="{DynamicResource ModernCard}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 统计周期按钮 -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Style="{DynamicResource ModernButton}" Content="今天" Margin="0,0,8,0"
                                        Command="{Binding SetTodayCommand}"/>
                                <Button Style="{DynamicResource ModernButton}" Content="本周" Margin="0,0,8,0"
                                        Command="{Binding SetThisWeekCommand}"/>
                                <Button Style="{DynamicResource ModernButton}" Content="本月" Margin="0,0,8,0"
                                        Command="{Binding SetThisMonthCommand}"/>
                                <Button Style="{DynamicResource ModernButton}" Content="自定义"
                                        Command="{Binding SetCustomCommand}"/>
                            </StackPanel>

                            <!-- 日期选择器 + 刷新 -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <DatePicker SelectedDate="{Binding StartDate, Mode=TwoWay}" Width="124"/>
                                <TextBlock Text="—" VerticalAlignment="Center" Margin="8,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <DatePicker SelectedDate="{Binding EndDate, Mode=TwoWay}" Width="124"/>
                                <Button Style="{DynamicResource ModernButton}" Content="刷新" Margin="12,0,0,0"
                                        Command="{Binding RefreshCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 当前周期标签 -->
                    <TextBlock Grid.Row="1" Text="{Binding SelectedPeriodName}"
                               Style="{DynamicResource ModernSectionTitle}" Margin="4,0,0,10"/>

                    <!-- 视图宿主：隐藏表头的 TabControl，由侧边栏 SelectedIndex 驱动 -->
                    <TabControl Grid.Row="2" SelectedIndex="{Binding SelectedTabIndex}"
                                Background="Transparent" BorderThickness="0" Padding="0">
                        <TabControl.Template>
                            <ControlTemplate TargetType="TabControl">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </ControlTemplate>
                        </TabControl.Template>
                        <TabItem>
                            <views:DashboardView DataContext="{Binding Dashboard}"/>
                        </TabItem>
                        <TabItem>
                            <views:AppListView DataContext="{Binding AppList}"/>
                        </TabItem>
                        <TabItem>
                            <views:CategoryView DataContext="{Binding Category}"/>
                        </TabItem>
                        <TabItem>
                            <views:SettingsView DataContext="{Binding Settings}"/>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
