<Application x:Class="ScreenWatch.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ScreenWatch.App"
             xmlns:conv="clr-namespace:ScreenWatch.App.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 默认加载浅色主题，启动后由 ThemeService 根据设置动态切换 -->
                <ResourceDictionary Source="Themes/ModernTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:DurationConverter x:Key="DurationConverter"/>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <conv:EmptyToVisibilityConverter x:Key="EmptyToVisibilityConverter"/>
            <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
